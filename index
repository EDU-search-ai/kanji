        { q: "みかんの ★おもさ★を はかる。", h: "おもさ", a: "重さ" },
        { q: "★つぎ★の ひと、どうぞ。", h: "つぎ", a: "次" },
        { q: "こうえんに ★あつまる★。", h: "あつまる", a: "集まる" },
        { q: "★あんぜん★に きをつける。", h: "あんぜん", a: "安全" },
        { q: "しゃしんを ★うつす★。", h: "うつす", a: "写す" },
        { q: "うみの ★うた★を うたう。", h: "うた", a: "詩" },
        { q: "たいこを ★うつ★。", h: "うつ", a: "打つ" },
        { q: "えいがの ★かんそう★を かく。", h: "かんそう", a: "感想" },
        { q: "★うんどう★かいの れんしゅう。", h: "うんどう", a: "運動" },
        { q: "★えいご★を はなす。", h: "えいご", a: "英語" },
        { q: "えきで ★えきべん★を かう。", h: "えきべん", a: "駅弁" },
        { q: "おへやを ★おおそうじ★ する。", h: "おおそうじ", a: "大掃除" },
        { q: "★おなじ★ おもちゃを もつ。", h: "おなじ", a: "同じ" },
        { q: "★おんがく★の じかん。", h: "おんがく", a: "音楽" },
        { q: "★かぞく★で ドライブに いく。", h: "かぞく", a: "家族" },
        { q: "★かわ★の ながれを みる。", h: "かわ", a: "川" },
        { q: "★かんしゃ★の きもちをつたえる。", h: "かんしゃ", a: "感謝" },
        { q: "★かんぜん★に おぼえる。", h: "かんぜん", a: "完全" },
        { q: "★きせつ★が かわる。", h: "きせつ", a: "季節" },
        { q: "きしゃが ★きゅう★に とまる。", h: "きゅう", a: "急" },
        { q: "★きょうしつ★に はいる。", h: "きょうしつ", a: "教室" },
        { q: "★きょねん★の おもいで。", h: "きょねん", a: "去年" },
        { q: "★きんじょ★の おばさん。", h: "きんじょ", a: "近所" },
        { q: "★ぎんこう★でおかねを おろす。", h: "ぎんこう", a: "銀行" },
        { q: "★くすり★を のむ。", h: "くすり", a: "薬" },
        { q: "★くんれん★を おこなう。", h: "くんれん", a: "訓練" },
        { q: "★けいかく★を たてる。", h: "けいかく", a: "計画" },
        { q: "★けいさつ★の くるま。", h: "けいさつ", a: "警察" },
        { q: "ノートに ★けんきゅう★を まとめる。", h: "けんきゅう", a: "研究" },
        { q: "★けんこう★に まいにちを すごす。", h: "けんこう", a: "健康" },
        { q: "おみせの ★ごしゅじん★。", h: "ごしゅじん", a: "ご主人" },
        { q: "★こうちょう★せんせいのおはなし。", h: "こうちょう", a: "校長" },
        { q: "★さかみち★を かけあがる。", h: "さかみち", a: "坂道" },
        { q: "★さくひん★を かざる。", h: "さくひん", a: "作品" },
        { q: "★ざっし★を よむ。", h: "ざっし", a: "雑誌" },
        { q: "★しあい★で かつ。", h: "しあい", a: "試合" },
        { q: "★しつもん★に こたえる。", h: "しつもん", a: "質問" },
        { q: "★じてんしゃ★に のる。", h: "じてんしゃ", a: "自転車" },
        { q: "★じどうしゃ★が はしる。", h: "じどうしゃ", a: "自動車" },
        { q: "★しゃしん★を パチリ。", h: "しゃしん", a: "写真" },
        { q: "★しゅくだい★を わすれない。", h: "しゅくだい", a: "宿題" },
        { q: "★しょどう★を ならう。", h: "しょどう", a: "書道" },
        { q: "★しんごう★が あおに なる。", h: "しんごう", a: "信号" },
        { q: "★せいかつ★の リズム。", h: "せいかつ", a: "生活" },
        { q: "★せかい★を たびする。", h: "せかい", a: "世界" },
        { q: "★せんせい★の いうことを きく。", h: "せんせい", a: "先生" },
        { q: "★せんそう★のない くに。", h: "せんそう", a: "戦争" },
        { q: "★たいじゅう★を はかる。", h: "たいじゅう", a: "体重" },
        { q: "★ちず★を ひろげる。", h: "ちず", a: "地図" },
        { q: "★ちゅうい★を よく よむ。", h: "ちゅうい", a: "注意" },
        { q: "★てがみ★を ポストに いれる。", h: "てがみ", a: "手紙" },
        { q: "★てんき★よほうを みる。", h: "てんき", a: "天気" },
        { q: "★どうぶつ★えんに いく。", h: "どうぶつ", a: "動物" },
        { q: "★とくべつ★な プレゼント。", h: "とくべつ", a: "特別" },
        { q: "★にっき★を まいにち かく。", h: "にっき", a: "日記" },
        { q: "★はつめい★かなりたい。", h: "はつめい", a: "発明" },
        { q: "★ひこうき★が とぶ。", h: "ひこうき", a: "飛行機" },
        { q: "★びょういん★に いく。", h: "びょういん", a: "病院" },
        { q: "★ふく★を きがえる。", h: "ふく", a: "服" },
        { q: "★へや★を かたづける。", h: "へや", a: "部屋" },
        { q: "★べんきょう★が たのしい。", h: "べんきょう", a: "勉強" },
        { q: "★ほうこく★を まつ。", h: "ほうこく", a: "報告" },
        { q: "★まち★の あかりがきえる。", h: "まち", a: "街" },
        { q: "★まど★を あけて かぜを いれる。", h: "まど", a: "窓" },
        { q: "★まんが★を よむ。", h: "まんが", a: "漫画" },
        { q: "みずを ★みずうみ★に ながす。", h: "みずうみ", a: "湖" },
        { q: "★みどり★の はっぱ。", h: "みどり", a: "緑" },
        { q: "★みんな★で なかよく する。", h: "みんな", a: "皆" },
        { q: "★むら★の おまつり。", h: "むら", a: "村" },
        { q: "★やさい★を たべる。", h: "やさい", a: "野菜" },
        { q: "★ゆうがた★の いえじ。", h: "ゆうがた", a: "夕方" },
        { q: "★りか★の じっけん。", h: "りか", a: "理科" }
    ];

    let currentSessionQuizzes = []; // 今回解く10問
    let currentIndex = 0;
    let rightAnswersCount = 0; // 正解数

    const quizContainer = document.getElementById('quizContainer');
    const resultContainer = document.getElementById('resultContainer');
    const questionEl = document.getElementById('question');
    const answerArea = document.getElementById('answerArea');
    const answerText = document.getElementById('answerText');
    const actionBtn = document.getElementById('actionBtn');
    const scoreButtons = document.getElementById('scoreButtons');
    const progressEl = document.getElementById('progress');
    const canvasHint = document.getElementById('canvasHint');
    const scoreDisplay = document.getElementById('scoreDisplay');
    const commentBox = document.getElementById('commentBox');

    const canvas = document.getElementById('writeCanvas');
    const ctx = canvas.getContext('2d');
    let isDrawing = false;

    function resizeCanvas() {
        const rect = canvas.parentNode.getBoundingClientRect();
        canvas.width = rect.width - 8;
        canvas.height = 220;
        clearCanvas();
    }

    function setupCanvas() {
        ctx.strokeStyle = '#8999ff';
        ctx.lineWidth = 5;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseleave', stopDrawing);

        canvas.addEventListener('touchstart', (e) => {
            const touch = e.touches[0];
            const mouseEvent = new MouseEvent('mousedown', {clientX: touch.clientX, clientY: touch.clientY});
            canvas.dispatchEvent(mouseEvent);
            e.preventDefault();
        }, { passive: false });

        canvas.addEventListener('touchmove', (e) => {
            const touch = e.touches[0];
            const mouseEvent = new MouseEvent('mousemove', {clientX: touch.clientX, clientY: touch.clientY});
            canvas.dispatchEvent(mouseEvent);
            e.preventDefault();
        }, { passive: false });

        canvas.addEventListener('touchend', () => {
            const mouseEvent = new MouseEvent('mouseup', {});
            canvas.dispatchEvent(mouseEvent);
        });
    }

    function startDrawing(e) {
        isDrawing = true;
        canvasHint.style.display = 'none';
        ctx.beginPath();
        const rect = canvas.getBoundingClientRect();
        ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
    }

    function draw(e) {
        if (!isDrawing) return;
        const rect = canvas.getBoundingClientRect();
        ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
        ctx.stroke();
    }

    function stopDrawing() { isDrawing = false; }
    function clearCanvas() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        canvasHint.style.display = 'block';
    }

    // 全70問からランダムに10問だけをえらびだす関数
    function prepareSession() {
        // 元のデータをシャッフル
        const shuffled = [...allQuizData];
        for (let i = shuffled.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        // 先頭の10問だけを今回のクイズにする
        currentSessionQuizzes = shuffled.slice(0, 10);
        currentIndex = 0;
        rightAnswersCount = 0;
    }

    function loadQuiz() {
        const currentQuiz = currentSessionQuizzes[currentIndex];
        progressEl.innerText = `だい ${currentIndex + 1} 問 / 全 10 問`;
        
        let formattedQuestion = currentQuiz.q.replace(/★(.*?)★/g, '<span class="highlight">$1</span>');
        questionEl.innerHTML = formattedQuestion;
        answerText.innerText = currentQuiz.a;
        
        answerArea.style.display = 'none';
        actionBtn.style.display = 'block';
        scoreButtons.style.display = 'none';
        clearCanvas();
    }

    // 「せいかいを みる」をおしたとき
    function showAnswer() {
        answerArea.style.display = 'block';
        actionBtn.style.display = 'none';
        scoreButtons.style.display = 'flex'; // まるばつボタンを出す
    }

    // 「できた！」「おしかった」のどちらかをおしたとき
    function nextQuestion(isCorrect) {
        if (isCorrect) rightAnswersCount++;

        currentIndex++;
        if (currentIndex < 10) {
            loadQuiz();
        } else {
            showResult();
        }
    }

    // 10問おわったあとの結果がめんと、やる気アップコメント
    function showResult() {
        quizContainer.style.display = 'none';
        resultContainer.style.display = 'block';
        
        scoreDisplay.innerText = `${rightAnswersCount} / 10`;
        
        // 点数にあわせた、ゆめかわ風やる気アップコメント
        let comment = "";
        if (rightAnswersCount === 10) {
            comment = "✨ パーフェクト！すごすぎるよぉお！ 💖<br>かん字のてんさいだね 🦄 このちょうしで、つぎのレッスンも 完ぺきを めざしちゃおう 🌟";
        } else if (rightAnswersCount >= 8) {
            comment = "✨ おおあたり！とっても おおきな まるっ！ 💮<br>めちゃくちゃ がんばったね！あとすこしで パーフェクトだよ 💕 つぎも いってみよう！ ✨";
        } else if (rightAnswersCount >= 5) {
            comment = "🌟 ナイスチャレンジ！半分以上できたよ ♫ 💖<br>まいにち すこしずつ おぼえていけば、ぜったい もっと 点数アップできるよ 🦄 ファイトっ！ ✨";
        } else {
            comment = "💧 よくがんばったね！えらすぎるよ 🧸✨<br>まちがえた かん字は 魔法のパワーにかわるよ 🔮 もういちど やれば、つぎは もっと たくさん できるよ 💖";
        }
        commentBox.innerHTML = comment;
    }

    // もういちどはじめから遊ぶとき
    function startNewSession() {
        resultContainer.style.display = 'none';
        quizContainer.style.display = 'block';
        prepareSession();
        loadQuiz();
    }

    window.onload = () => {
        prepareSession();
        resizeCanvas();
        setupCanvas();
        loadQuiz();
    };

    window.addEventListener('resize', resizeCanvas);
</script>

</body>
</html>
