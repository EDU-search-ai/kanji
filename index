<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>ゆめかわ♡かん字レッスン</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Kosugi+Maru&display=swap');

        body {
            font-family: 'Kosugi Maru', sans-serif;
            background: linear-gradient(135deg, #ffe3f1 0%, #e6e6ff 100%);
            color: #6a5acd;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 10px;
            box-sizing: border-box;
            touch-action: manipulation;
        }
        .container {
            background-color: rgba(255, 255, 255, 0.9);
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(230, 180, 210, 0.5);
            padding: 20px;
            width: 95%;
            max-width: 480px;
            text-align: center;
            border: 5px solid #ffb7dd;
            position: relative;
        }
        h1 {
            color: #ff6ebb;
            font-size: 22px;
            margin-top: 5px;
            margin-bottom: 10px;
            text-shadow: 2px 2px 0px #fff, 3px 3px 0px #e6e6ff;
        }
        .progress {
            font-size: 14px;
            color: #9b89ff;
            font-weight: bold;
            margin-bottom: 15px;
            background: #fff0f7;
            padding: 5px 15px;
            border-radius: 20px;
            display: inline-block;
            border: 2px dashed #ffcde5;
        }
        .card {
            background-color: #fffaf0;
            border: 3px solid #cee7ff;
            border-radius: 16px;
            padding: 20px 15px;
            margin-bottom: 15px;
            box-shadow: inset 0 0 10px rgba(206,231,255,0.5);
        }
        .question {
            font-size: 24px;
            font-weight: bold;
            letter-spacing: 1px;
            line-height: 1.5;
        }
        .highlight {
            color: #ff5599;
            border-bottom: 3px dotted #ff5599;
            padding: 0 4px;
            background: #ffe9f3;
            border-radius: 4px;
        }
        
        .canvas-area {
            position: relative;
            margin: 15px 0;
            background: #ffffff;
            border: 4px dashed #bbf2e7;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        .canvas-hint {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #d0caff;
            font-size: 16px;
            pointer-events: none;
            z-index: 1;
            width: 80%;
            line-height: 1.6;
        }
        canvas {
            display: block;
            background: transparent;
            position: relative;
            z-index: 2;
            touch-action: none;
            cursor: crosshair;
        }
        
        .tools {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }
        .btn-clear {
            background-color: #bbf2e7;
            color: #2b7a6c;
            flex: 1;
        }
        .btn-clear:hover { background-color: #9eeadd; }
        
        button {
            border: none;
            border-radius: 25px;
            padding: 12px 20px;
            font-size: 16px;
            font-weight: bold;
            font-family: 'Kosugi Maru', sans-serif;
            cursor: pointer;
            transition: all 0.1s;
        }

        .btn-main {
            background: linear-gradient(to bottom, #ff9ecd, #ff6ebb);
            color: white;
            width: 100%;
            font-size: 20px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
            box-shadow: 0 4px 0px #ff4a9e;
        }
        .btn-main:active {
            transform: translateY(4px);
            box-shadow: none;
        }
        
        /* 自己採点ボタン */
        .score-buttons {
            display: none;
            gap: 15px;
            margin-top: 10px;
        }
        .btn-ox {
            flex: 1;
            font-size: 18px;
            box-shadow: 0 4px 0px rgba(0,0,0,0.1);
        }
        .btn-o {
            background: linear-gradient(to bottom, #ff9ebb, #ff5e97);
            color: white;
            box-shadow: 0 4px 0px #cc3b6e;
        }
        .btn-x {
            background: linear-gradient(to bottom, #bfeeff, #7ed6ff);
            color: #1e6b91;
            box-shadow: 0 4px 0px #4faedb;
        }
        .btn-ox:active {
            transform: translateY(4px);
            box-shadow: none;
        }
        
        .answer-area {
            display: none;
            background: #fff0f7;
            border: 3px double #ff9ecd;
            border-radius: 16px;
            padding: 15px;
            margin-bottom: 15px;
            animation: popIn 0.3s ease;
        }
        .answer-title {
            font-size: 14px;
            color: #ff6ebb;
            margin-bottom: 5px;
        }
        .answer-text {
            font-size: 42px;
            font-weight: bold;
            color: #ff4757;
            letter-spacing: 5px;
        }

        /* 結果画面 */
        .result-screen {
            display: none;
            animation: popIn 0.4s ease;
        }
        .result-title {
            font-size: 26px;
            color: #ff5e97;
            margin-bottom: 15px;
            font-weight: bold;
        }
        .score-display {
            font-size: 48px;
            font-weight: bold;
            color: #8999ff;
            margin-bottom: 20px;
            background: #ffffff;
            border-radius: 50%;
            width: 140px;
            height: 140px;
            line-height: 140px;
            display: inline-block;
            border: 5px double #bbf2e7;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
        .comment-box {
            background: #fff5fa;
            border: 2px dashed #ffb7dd;
            border-radius: 16px;
            padding: 15px;
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 25px;
            color: #555;
        }
        .btn-restart {
            background: linear-gradient(to bottom, #b3beff, #8999ff);
            color: white;
            width: 100%;
            font-size: 20px;
            box-shadow: 0 4px 0px #5c6eff;
        }
        .btn-restart:active {
            transform: translateY(4px);
            box-shadow: none;
        }

        @keyframes popIn {
            0% { transform: scale(0.9); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body>

<div class="container">
    <div id="quizContainer">
        <h1>🔮 ゆめかわ かん字レッスン ✨</h1>
        <div class="progress" id="progress">だい 1 問 / 全 10 問</div>
        
        <div class="card">
            <div class="question" id="question"></div>
        </div>

        <div class="canvas-area">
            <div class="canvas-hint" id="canvasHint">ここに ゆびやペンで<br>かん字を かいてね！</div>
            <canvas id="writeCanvas" width="400" height="220"></canvas>
        </div>

        <div class="tools">
            <button class="btn-clear" onclick="clearCanvas()">もどす（けす）</button>
        </div>

        <div class="answer-area" id="answerArea">
            <div class="answer-title">💖 せいかい 💖</div>
            <div class="answer-text" id="answerText"></div>
        </div>

        <button id="actionBtn" class="btn-main" onclick="showAnswer()">せいかいを みる 🌟</button>
        
        <div class="score-buttons" id="scoreButtons">
            <button class="btn-ox btn-x" onclick="nextQuestion(false)">おしかった 💧</button>
            <button class="btn-ox btn-o" onclick="nextQuestion(true)">できた！ 💮</button>
        </div>
    </div>

    <div id="resultContainer" class="result-screen">
        <div class="result-title">🎉 レッスン おわり 🎉</div>
        <div class="score-display" id="scoreDisplay">0 / 10</div>
        <div class="comment-box" id="commentBox"></div>
        <button class="btn-restart" onclick="startNewSession()">もういちど チャレンジ 🦄</button>
    </div>
</div>

<script>
    // 3年生の漢字（全70問）
    const allQuizData = [
